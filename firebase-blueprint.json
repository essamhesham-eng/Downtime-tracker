{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "engineer", "line_leader", "maintenance_engineer", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Line": {
      "title": "Production Line",
      "description": "A manufacturing production line",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "allowOutOfOrder": { "type": "boolean", "description": "Whether this line allows reporting 'out of order' incidents" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Machine": {
      "title": "Machine",
      "description": "A machine on a production line",
      "type": "object",
      "properties": {
        "lineId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["running", "down"] },
        "currentIncidentId": { "type": ["string", "null"] },
        "order": { "type": "number" },
        "defaultMEs": { "type": ["array", "null"], "items": { "type": "string" } },
        "isCritical": { "type": "boolean" },
        "jigs": { "type": ["number", "null"] },
        "wip": { "type": ["number", "string", "null"] },
        "category": { "type": "string", "enum": ["assembly", "test", "packing"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["lineId", "name", "status", "category", "createdAt"]
    },
    "Incident": {
      "title": "Downtime Incident",
      "description": "A record of machine downtime",
      "type": "object",
      "properties": {
        "lineId": { "type": "string" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "lineName": { "type": "string" },
        "reportedBy": { "type": "string" },
        "reportedByName": { "type": ["string", "null"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": ["string", "null"], "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "acknowledged", "resolved"] },
        "acknowledgedBy": { "type": ["string", "null"] },
        "acknowledgedAt": { "type": ["string", "null"], "format": "date-time" },
        "resolvedBy": { "type": ["string", "null"] },
        "resolvedByName": { "type": ["string", "null"] },
        "durationMinutes": { "type": ["number", "null"] },
        "assignedTo": { "type": ["array", "null"], "items": { "type": "string" } },
        "breakdownJigs": { "type": ["number", "null"] },
        "totalJigs": { "type": ["number", "null"] }
      },
      "required": ["lineId", "machineId", "machineName", "lineName", "reportedBy", "startTime", "status"]
    },
    "Group": {
      "title": "User Group",
      "description": "A group of users",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userIds": { "type": ["array", "null"], "items": { "type": "string" } }
      },
      "required": ["name"]
    },
    "Setting": {
      "title": "Application Setting",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "emails": { "type": ["array", "null"], "items": { "type": "string" } },
        "monthlyDay": { "type": "number" },
        "monthlyTime": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Invitation": {
      "title": "User Invitation",
      "description": "An invitation for a user to join the application",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": ["string", "null"] },
        "role": { "type": "string", "enum": ["admin", "manager", "engineer", "line_leader", "maintenance_engineer", "pending"] },
        "status": { "type": "string", "enum": ["invited", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "invitedBy": { "type": "string" }
      },
      "required": ["email", "role", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "/invitations/{email}": {
      "schema": { "$ref": "#/entities/Invitation" },
      "description": "User invitations"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Application settings"
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/Group" },
      "description": "User groups"
    },
    "/lines/{lineId}": {
      "schema": { "$ref": "#/entities/Line" },
      "description": "Production lines"
    },
    "/machines/{machineId}": {
      "schema": { "$ref": "#/entities/Machine" },
      "description": "Machines"
    },
    "/incidents/{incidentId}": {
      "schema": { "$ref": "#/entities/Incident" },
      "description": "Downtime incidents"
    }
  }
}